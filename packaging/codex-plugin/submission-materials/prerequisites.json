    {
      "id": "Q01-publisher-mode",
      "sequence": 1,
      "status": "answered",
      "decision_authority": "publisher",
      "depends_on": [],
      "blocker_ids": [
        "verified_publisher_identity"
      ],
      "question_zh": "CoTend 首次提交应使用个人身份还是企业身份完成发布者验证？",
      "why_it_matters_zh": "发布者类型会约束开发者名称、公开法律与支持信息、目标组织权限以及身份验证路径。",
      "recommended_option_id": "1",
      "options": [
        {
          "id": "1",
          "label_zh": "个人身份首发",
          "impact_zh": "准备项通常更少，但提交材料中的开发者名称和公开信息需要与已验证个人身份一致，可能暴露个人名称。"
        },
        {
          "id": "2",
          "label_zh": "企业身份首发",
          "impact_zh": "品牌与个人身份分离更清晰，但需要可验证的企业身份、对应组织权限和一致的公开法律信息。"
        },
        {
          "id": "3",
          "label_zh": "暂缓决定",
          "impact_zh": "保持所有依赖项阻塞，不进行身份验证、公开页面定案或 Portal 操作。"
        }
      ],
      "answer": "1",
      "evidence": {
        "evidence_type": "user_explicit",
        "recorded_on": "2026-07-14",
        "scope": "publisher_mode_route_only_not_identity_verification"
      }
    },
    {
      "id": "Q02-final-plugin-identity",
      "sequence": 2,
      "status": "answered",
      "decision_authority": "publisher",
      "depends_on": [
        "Q01-publisher-mode"
      ],
      "blocker_ids": [
        "final_plugin_identity_and_version"
      ],
      "question_zh": "是否把当前 cotend@0.1.0-rc.1 候选作为首次提交身份与版本，还是先调整？",
      "why_it_matters_zh": "最终身份会决定 manifest、package lock、logo、公开页面和后续更新兼容性，候选值本身不等于发布授权；OpenAI Platform 对预发布版本的实际接受尚未验证。",
      "recommended_option_id": "1",
      "options": [
        {
          "id": "1",
          "label_zh": "沿用当前候选",
          "impact_zh": "保留已经通过隔离验证的 ID 和预发布版本，再执行最终重建与全量回归；OpenAI Platform 对预发布版本的实际接受尚未验证，若 Portal 不接受则必须重新打开 Q02。"
        },
        {
          "id": "2",
          "label_zh": "提交前调整",
          "impact_zh": "先重新决定 ID 或版本，并重建 package、submission 合同和全部绑定证据。"
        },
        {
          "id": "3",
          "label_zh": "暂缓决定",
          "impact_zh": "不修改 manifest 或 lock，依赖最终身份的 logo 和公开页面继续阻塞。"
        }
      ],
      "answer": "1",
      "evidence": {
        "evidence_type": "user_explicit",
        "recorded_on": "2026-07-14",
        "scope": "final_plugin_identity_and_version_only_not_submission_or_release"
      }
    },
    {
      "id": "Q03-public-web-presence",
      "sequence": 3,
      "status": "answered",
      "decision_authority": "publisher",
      "depends_on": [
        "Q01-publisher-mode",
        "Q02-final-plugin-identity"
      ],
      "blocker_ids": [
        "website_url",
        "support_url",
        "privacy_policy_url",
        "terms_url"
      ],
      "question_zh": "CoTend 的 website、support、privacy policy 和 terms 应采用哪种可公开访问的承载方式？",
      "why_it_matters_zh": "四个 URL 必须真实可访问、职责清楚，并与最终发布者身份和支持范围一致。",
      "recommended_option_id": "1",
      "options": [
        {
          "id": "1",
          "label_zh": "GitHub 优先承载",
          "impact_zh": "优先使用公开仓库、Issues 和可公开托管的法律页面，基础设施最少，但上线前仍需逐个验证 URL 和身份一致性。"
        },
        {
          "id": "2",
          "label_zh": "独立站点承载",
          "impact_zh": "品牌控制更完整，但增加域名、托管、维护和法律页面发布工作。"
        },
        {
          "id": "3",
          "label_zh": "暂缓决定",
          "impact_zh": "不创建占位 URL，四个公开页面 blocker 保持未解决。"
        }
      ],
      "answer": "1",
      "evidence": {
        "evidence_type": "user_explicit",
        "recorded_on": "2026-07-14",
        "scope": "public_web_presence_hosting_route_only_not_urls_or_publication"
      }
    },
    {
